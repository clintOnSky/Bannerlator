<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <LinearLayout
        android:id="@+id/RowFPS"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginLeft="10dp"
        android:gravity="center_vertical"
        android:background="#33000000">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FPS:" android:textColor="#0277bd" android:textStyle="bold" android:textSize="12sp" android:layout_marginRight="5dp" />
        <TextView android:id="@+id/TVFPS" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#ffffff" android:textStyle="bold" android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/RowCPULoad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginLeft="10dp"
        android:gravity="center_vertical"
        android:background="#33000000">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CPU Temp:" android:textColor="#ffeb3b" android:textStyle="bold" android:textSize="12sp" android:layout_marginRight="5dp" />
        <TextView android:id="@+id/TVCPULoad" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0°C" android:textColor="#ffffff" android:textStyle="bold" android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/RowRenderer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginLeft="10dp"
        android:gravity="center_vertical"
        android:background="#33000000">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Renderer:" android:textColor="#fc0303" android:textStyle="bold" android:textSize="12sp" android:layout_marginRight="5dp" />
        <TextView android:id="@+id/TVRenderer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#ffffff" android:textStyle="bold" android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/RowGPU"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginLeft="10dp"
        android:gravity="center_vertical"
        android:background="#33000000">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GPU:" android:textColor="#5c23a6" android:textStyle="bold" android:textSize="12sp" android:layout_marginRight="5dp" />
        <TextView android:id="@+id/TVGPU" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#ffffff" android:textStyle="bold" android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/RowGPULoad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginLeft="10dp"
        android:gravity="center_vertical"
        android:background="#33000000">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GPU Load:" android:textColor="#ff6f00" android:textStyle="bold" android:textSize="12sp" android:layout_marginRight="5dp" />
        <TextView android:id="@+id/TVGPULoad" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textColor="#ffffff" android:textStyle="bold" android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/RowRAM"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginLeft="10dp"
        android:gravity="center_vertical"
        android:background="#33000000">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RAM:" android:textColor="#23a6a4" android:textStyle="bold" android:textSize="12sp" android:layout_marginRight="5dp" />
        <TextView android:id="@+id/TVRAM" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#ffffff" android:textStyle="bold" android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/RowBatteryTemp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginLeft="10dp"
        android:gravity="center_vertical"
        android:background="#33000000">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Batt Temp:" android:textColor="#ff9800" android:textStyle="bold" android:textSize="12sp" android:layout_marginRight="5dp" />
        <TextView android:id="@+id/TVBatteryTemp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0°C" android:textColor="#ffffff" android:textStyle="bold" android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/RowBatteryVoltage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginLeft="10dp"
        android:gravity="center_vertical"
        android:background="#33000000">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Batt Volt:" android:textColor="#4caf50" android:textStyle="bold" android:textSize="12sp" android:layout_marginRight="5dp" />
        <TextView android:id="@+id/TVBatteryVoltage" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.​0W" android:textColor="#ffffff" android:textStyle="bold" android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>

