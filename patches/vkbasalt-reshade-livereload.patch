+                    case reshadefx::type::t_float: std::memcpy(&raw, &uniformInfo.initializer_value.as_float[c], sizeof(uint32_t)); break;
+                    case reshadefx::type::t_int:   std::memcpy(&raw, &uniformInfo.initializer_value.as_int[c], sizeof(uint32_t)); break;
+                    case reshadefx::type::t_uint:
+                    case reshadefx::type::t_bool:  std::memcpy(&raw, &uniformInfo.initializer_value.as_uint[c], sizeof(uint32_t)); break;
+                    default: break;
+                }
+            }
+            std::memcpy(value.data() + c * sizeof(uint32_t), &raw, sizeof(uint32_t));
+        }
+
+        // Apply any config override on top of the default.
+        setFromConfig(config, effectName);
+    }
+
+    void GenericUniform::setFromConfig(Config& config, const std::string& effectName)
+    {
+        const std::string base = effectName + "_" + uniformName;
+        for (uint32_t c = 0; c < components && (c + 1) * sizeof(uint32_t) <= size; c++)
+        {
+            // Scalars use "<effect>_<name>"; vectors use "<effect>_<name>_<c>".
+            const std::string key = (components > 1) ? (base + "_" + std::to_string(c)) : base;
+
+            // Read current cached value as the default so a missing key is a no-op.
+            uint32_t raw = 0;
+            std::memcpy(&raw, value.data() + c * sizeof(uint32_t), sizeof(uint32_t));
+
+            switch (baseType)
+            {
+                case reshadefx::type::t_float:
+                {
+                    float cur;
+                    std::memcpy(&cur, &raw, sizeof(float));
+                    float v = config.getOption<float>(key, cur);
+                    std::memcpy(&raw, &v, sizeof(uint32_t));
+                    break;
+                }
+                case reshadefx::type::t_int:
+                {
+                    int32_t v = config.getOption<int32_t>(key, (int32_t) raw);
+                    std::memcpy(&raw, &v, sizeof(uint32_t));
+                    break;
+                }
+                case reshadefx::type::t_uint:
+                {
+                    int32_t v = config.getOption<int32_t>(key, (int32_t) raw);
+                    raw       = (uint32_t) v;
+                    break;
+                }
+                case reshadefx::type::t_bool:
+                {
+                    bool     v   = config.getOption<bool>(key, raw != 0);
+                    VkBool32 vb  = v ? VK_TRUE : VK_FALSE;
+                    std::memcpy(&raw, &vb, sizeof(uint32_t));
+                    break;
+                }
+                default: break;
+            }
+            std::memcpy(value.data() + c * sizeof(uint32_t), &raw, sizeof(uint32_t));
+        }
+    }
+
+    void GenericUniform::update(void* mapedBuffer)
+    {
+        if (!value.empty())
+            std::memcpy((uint8_t*) mapedBuffer + offset, value.data(), value.size());
+    }
+    GenericUniform::~GenericUniform()
+    {
+    }
 } // namespace vkBasalt
